# --- LLM / Embeddings ---
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...

# --- Supabase ---
# URL del proyecto y la SERVICE ROLE key (el backend necesita escribir en las tablas).
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# --- Modelos (defaults; se pueden overridear) ---
GEN_MODEL=claude-opus-4-8
JUDGE_MODEL=claude-haiku-4-5
EMBED_MODEL=voyage-3.5
EMBED_DIM=1024

# --- Retrieval ---
TOP_K=5

# --- CORS: origen del frontend Next.js ---
CORS_ORIGINS=http://localhost:3000

# --- Frontend (apps/web) ---
# URL del backend FastAPI, usada por el route handler de Next para proxear.
API_BASE_URL=http://localhost:8000
